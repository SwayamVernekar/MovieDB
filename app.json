{
  "expo": {
    "name": "MovieDB",
    "slug": "MovieDB",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/mdb.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/mdb.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/mdb.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.MovieDB"
    },
    "web": {
      "favicon": "./assets/mdb.png",
      "bundler": "metro",
      "output": "single"
    }
  }
}
